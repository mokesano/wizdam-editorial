<schema version="0.2">

	<!--
	  *
	  * TABLE Invoices
	  *
	  -->
    <table name="invoices">
        <field name="invoice_id" type="I8"><KEY/><AUTOINCREMENT/></field>
        <field name="journal_id" type="I8"><NOTNULL/></field>
        <field name="user_id" type="I8"><NOTNULL/></field>
        <field name="submission_id" type="I8" />
        <field name="invoice_number" type="C2" size="50" />
        <field name="invoice_code" type="C2" size="50" />
        <field name="fee_type" type="C2" size="50"><NOTNULL/></field>
        <field name="amount" type="F"><NOTNULL/></field>
        <field name="currency_code" type="C2" size="3"><NOTNULL/></field>
        <field name="status" type="C2" size="20"><NOTNULL/><DEFAULT VALUE="UNPAID"/></field>
        <field name="payment_method" type="C2" size="50" />
        <field name="date_billed" type="T"><NOTNULL/></field>
        <field name="date_paid" type="T" />
        
        <index name="invoices_journal_id"><col>journal_id</col></index>
        <index name="invoices_user_id"><col>user_id</col></index>
        <index name="invoices_submission_id"><col>submission_id</col></index>
    </table>
    
</schema>