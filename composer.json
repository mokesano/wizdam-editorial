{
    "name": "wizdam/wizdam-platform",
    "description": "Wizdam Publisher Platform - Modern Open Journal Systems Framework",
    "type": "project",
    "license": "GPL-2.0-only",
    "keywords": [
        "ojs",
        "publishing",
        "journal",
        "open-access",
        "wizdam"
    ],
    "homepage": "https://wizdam.sangia.org/",
    "support": {
        "issues": "https://github.com/wizdam/wizdam/issues",
        "forum": "https://forum.wizdam.sangia.org/",
        "source": "https://github.com/wizdam/wizdam"
    },
    "authors": [
        {
            "name": "Rochmady",
            "email": "admin@wizdam.sangia.org",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-xml": "*",
        "ext-curl": "*",
        "ext-zip": "*",
        "ext-gd": "*",
        "vlucas/phpdotenv": "^5.5",
        "guzzlehttp/guzzle": "^7.0",
        "mpdf/mpdf": "^8.0",
        "setasign/fpdi": "^2.0",
        "chillerlan/php-qrcode": "^4.4",
        "midtrans/midtrans-php": "^2.6",
        "xendit/xendit-php": "^2.0",
        "smarty/smarty": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Wizdam\\Core\\": [
                "core/Library/",
                "core/Includes/"
            ],
            "App\\": [
                "app/Classes/",
                "app/Pages/",
                "app/Controllers/",
                "app/Services/",
                "app/Helpers/"
            ]
        },
        "classmap": [
            "core/Library/adodb/",
            "core/Library/smarty/",
            "core/Library/htmlpurifier/library/",
            "resources/smarty/plugins/",
            "plugins/"
        ],
        "files": [
            "core/Includes/functions.inc.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Wizdam\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "vendor-dir": "core/Library/vendor"
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"echo 'Wizdam Platform installed successfully!\\n';\""
        ],
        "post-update-cmd": [
            "@php -r \"echo 'Wizdam Platform updated successfully!\\n';\""
        ],
        "test": "phpunit",
        "cs-check": "phpcs --standard=PSR12 core/Library app",
        "cs-fix": "phpcbf --standard=PSR12 core/Library app",
        "analyze": "phpstan analyse --level max core/Library app"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
