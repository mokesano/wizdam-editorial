# ====================================================================
# KONFIGURASI .HTACCESS UNTUK SANGIA PUBLISHING
# Tujuan: Mengatur URL rewriting, keamanan, dan konfigurasi PHP
# ====================================================================

# ====================================================================
# WIZDAM ERROR HANDLING
# ====================================================================

# 1. Client Errors (4xx)
# 400 Bad Request: Permintaan browser rusak/malformed
ErrorDocument 400 /400.shtml
# 403 Authorization required: Akses ditolak atau izin file
ErrorDocument 401 /401.shtml
# 403 Forbidden: Akses ditolak oleh WAF atau izin file
ErrorDocument 403 /403.shtml
# 404 Not Found: File statis tidak ditemukan (Lihat catatan di bawah)
ErrorDocument 404 /404.shtml
# 423 Locked: Resource terkunci (Jarang di OJS, tapi bagus jika ada)
ErrorDocument 423 /423.shtml

# 2. Server Errors (5xx)
# 500 Internal Server Error: Script PHP crash atau salah config
ErrorDocument 500 /500.shtml
# 503 Service Unavailable: Server overload atau sedang Maintenance
ErrorDocument 503 /503.shtml

# ===================================================================
# WIZDAM WAF v2.0 - Server-Level Protection
# ===================================================================

# STEP C: Direct file blocking (Malware & Spy Scripts)
<FilesMatch "^(zip|shell|c99|r57|wso|b374k|alfa|indoxploit|mini|adminer|info|phpinfo|test|temp)\.php$">
    Require all denied
</FilesMatch>

# STEP D: Protect sensitive & System files
# Memblokir akses ke file .wiz, .tpl, .inc, .log, dll.
<FilesMatch "\.(inc|conf|config|log|sql|bak|old|backup|git|svn|env|ini|sh|tpl|wiz|md|yml)$">
    Require all denied
</FilesMatch>

# STEP F: Protect Apache Config Files
<FilesMatch "^\.ht">
    Require all denied
</FilesMatch>

# --------------------------------------------------------------------
# BAGIAN 1: KONFIGURASI PHP
# Mengatur parameter PHP untuk upload file dan timezone
# --------------------------------------------------------------------

# Mengatur timezone server ke Jakarta (WIB)
# Memastikan semua timestamp menggunakan waktu Indonesia
php_value date.timezone 'Asia/Jakarta'

# --------------------------------------------------------------------
# BAGIAN 2: KEAMANAN DIREKTORI
# Mencegah browsing direktori dan listing file
# --------------------------------------------------------------------

# Menonaktifkan directory browsing untuk keamanan
# Mencegah pengunjung melihat daftar file dalam direktori
Options All -Indexes

# Menyembunyikan semua file dari directory listing
# Backup keamanan jika Options -Indexes tidak bekerja
IndexIgnore *

# --------------------------------------------------------------------
# BAGIAN 3: URL REWRITING - KONFIGURASI UTAMA
# Mengatur bagaimana URL diproses dan dialihkan
# --------------------------------------------------------------------

# REDIRECT NON-WWW KE WWW
# Tujuan: Standarisasi domain untuk SEO dan konsistensi
# Contoh: journals.sangia.org → www.journals.sangia.org
# RewriteCond %{HTTP_HOST} ^journals\.sangia\.org$ [NC]
# RewriteRule ^(.*)$ https://www.journals.sangia.org/$1 [R=301,L]


<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP_USER_AGENT} ^-?$ [OR]
RewriteCond %{HTTP_USER_AGENT} ^$
RewriteRule ^ - [F,L]
 # ----------------------------------------------------------------
 # BAGIAN 5: API ENDPOINTS - CUSTOM APLIKASI
 # Mengarahkan URL API ke file PHP handler yang sesuai
 # ----------------------------------------------------------------
 
 # API SINTA IMPACT FACTOR
 # Endpoint: /api/sinta
 # Fungsi: Mengambil data impact factor dari database Sinta
 # [L,QSA] = Last rule + Query String Append
 RewriteRule ^api/sinta$ plugins/themes/sangiapub/php/sinta_impact/SintaProxyHandler.php [L,QSA]
 
 # API SINTA SCORE VERSION 2 (IMPROVED)
 # Endpoint: /api/sinta_v2  
 # Fungsi: Versi terbaru untuk mengambil skor Sinta journal
 RewriteRule ^api/sinta_v2$ plugins/themes/sangiapub/php/sinta_impact/SintaScoreNEW.php [L,QSA]
 
 # API CITATION COUNT BY DOI
 # Endpoint: /api/citedby
 # Fungsi: Mengambil jumlah sitasi artikel berdasarkan DOI
 RewriteRule ^api/citedby$ plugins/themes/sangiapub/php/citations/doi_citation.php [L,QSA]
 
 # API SCOPUS EDITOR VERIFICATION
 # Endpoint: /api/scopus_editor
 # Fungsi: Memverifikasi apakah editor terdaftar di Scopus
 RewriteRule ^api/scopus_editor$ plugins/themes/sangiapub/php/editor_Scopus/scopus_editor.php [L,QSA]
 
 # API USER SCOPUS VERSION 2
 # Endpoint: /api/userscopus
 # Fungsi: Mengambil data author/editor dari database Scopus
 RewriteRule ^api/userscopus$ plugins/themes/sangiapub/php/editor_Scopus/editorInScopus_v31.php [L,QSA]
 RewriteRule ^api/scopus_user$ plugins/themes/sangiapub/php/editor_Scopus/UserScopus_v32.php [L,QSA]

 # API JOURNAL SCOPUS VERSION 1
 # Endpoint: /api/journalscopus
 # Fungsi: Mengambil data jurnal dari database Scopus
 RewriteRule ^api/journalscopus$ plugins/themes/sangiapub/php/Metrics_journal_scopus/journal_metrics.php [L,QSA]
 
 # API SDG MAPPING VERSION 2-5
 # Endpoint: /api/sdg_v2, /api/sdg_v3, /api/sdg_v4, /api/sdg_v5
 # Fungsi: Memetakan artikel ke Sustainable Development Goals (SDG)
 # Multiple versions untuk testing dan backward compatibility
 RewriteRule ^api/sdg_v2$ plugins/themes/sangiapub/php/sdg_mapper/sdg_mapping_v2.php [L,QSA]
 RewriteRule ^api/sdg_v3$ plugins/themes/sangiapub/php/sdg_mapper/sdg_mapping_v3.php [L,QSA]
 RewriteRule ^api/sdg_v4$ plugins/themes/sangiapub/php/sdg_mapper/sdg_mapping_v4.php [L,QSA]
 RewriteRule ^api/sdg_v5$ plugins/themes/sangiapub/php/sdg_mapper/sdg_mapping_v5.php [L,QSA]

 # API Interface SDG MAPPING VERSION 1
 # Endpoint: api/sdg
 # Fungsi: Visual peneliti dan artikel ke Sustainable Development Goals (SDG)
 # Version awal untuk testing dan backward compatibility
 RewriteRule ^api/sdg$ plugins/themes/sangiapub/php/sdg_mapper/SDGs_interface.php [L,QSA]
 
 # API ORCID RESEARCHER DATA
 # Endpoint: /api/orcid
 # Fungsi: Mengambil data peneliti dari ORCID database
 RewriteRule ^api/orcid$ plugins/themes/sangiapub/php/orcid_researcher/orcid_data.php [L,QSA]
 
 
 # ----------------------------------------------------------------
 # BAGIAN 6: KEAMANAN TEMA - PROTEKSI DIREKTORI
 # Mencegah akses langsung ke file tema untuk keamanan
 # ----------------------------------------------------------------
 
 # BLOKIR AKSES ROOT DIREKTORI TEMA
 # Mencegah: /plugins/themes/sangiapub/
 # Redirect ke halaman 403 Forbidden
 RewriteRule ^plugins/themes/sangiapub/?$ plugins/themes/sangiapub/403.shtml [L]
 
 # BLOKIR AKSES SUBDIRECTORY TEMA  
 # Mencegah: /plugins/themes/sangiapub/css/, /plugins/themes/sangiapub/js/, dll
 # Pattern ([^/]+) menangkap nama subdirectory apapun
 RewriteRule ^plugins/themes/sangiapub/([^/]+)/?$ plugins/themes/sangiapub/403.shtml [L]
 
 # BLOKIR AKSES FILE GAMBAR TEMA
 # Proteksi tambahan untuk file media dalam tema
 # Kondisi: File tidak exist (!-f) DAN direktori tidak exist (!-d)
 # Target: File dengan ekstensi gambar (png, jpg, jpeg, gif, bmp, svg, ico)
 RewriteCond %{REQUEST_FILENAME} !-f
 RewriteCond %{REQUEST_FILENAME} !-d
 RewriteRule ^plugins/themes/sangiapub/(.+\.(png|jpg|jpeg|gif|bmp|svg|ico))$ plugins/themes/sangiapub/403.shtml [L]
 
 
 # ----------------------------------------------------------------
 # BAGIAN 7: OJS CORE - URL ROUTING
 # Rule utama OJS untuk menangani semua request ke index.php
 # ----------------------------------------------------------------
 
 # Format: RewriteRule ^(path-jurnal)/halaman/OperasiLama$ /path-jurnal/halaman/operasi-baru [R=301,L]
 # RewriteRule ^([a-zA-Z0-9_]+)/issue/view/61$ /$1/volumes/9/issue/1 [R=301,L]
 RewriteRule ^([a-zA-Z0-9_]+)/about/journalSponsorship$ /$1/about/sponsorship [R=301,L]
 RewriteRule ^([a-zA-Z0-9_]+)/about/editorialTeam$ /$1/about/editorial-team [R=301,L]
 # RewriteRule ^([a-zA-Z0-9_]+)/about/editorialTeamBio$ /$1/about/editorial-team-bio [R=301,L]
 RewriteRule ^([a-zA-Z0-9_]+)/about/siteMap$ /$1/about/sitemap [R=301,L]
 RewriteRule ^([a-zA-Z0-9_]+)/about/editorialPolicies$ /$1/about/editorial-policies [R=301,L]
 RewriteRule ^([a-zA-Z0-9_]+)/about/aboutThisPublishingSystem$ /$1/about/insights [R=301,L]
 
 # RULE UTAMA OJS - FRONT CONTROLLER PATTERN
 # Kondisi: Request bukan file nyata (!-f) DAN bukan direktori nyata (!-d)
 # Aksi: Kirim semua request ke index.php dengan path sebagai parameter
 # [QSA] = Query String Append (pertahankan parameter URL)
 # [L] = Last rule (stop processing setelah rule ini)
 #
 # Contoh transformasi:
 # /search/titles → index.php/search/titles
 # /journal/view/123 → index.php/journal/view/123  
 # /article/view/456 → index.php/article/view/456
 RewriteCond %{REQUEST_FILENAME} !-d
 RewriteCond %{REQUEST_FILENAME} !-f
 RewriteRule ^(.*)$ index.php/$1 [QSA,L]
 
</IfModule>

# ----------------------------------------------------------------
